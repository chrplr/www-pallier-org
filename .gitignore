# --- Hugo Specifics ---
hugo-site/public/
hugo-site/resources/
hugo-site/.hugo_build.lock

# --- Sphinx Specifics ---
docs-sphinx/_build/
docs-sphinx/venv/
.pytest_cache/

# --- The "Sync" Folder ---
# This is crucial: we ignore the docs inside static because 
# they are generated by the Sphinx Makefile.
hugo-site/static/docs/*
!hugo-site/static/docs/.gitkeep

# --- OS Specifics ---
.DS_Store
Thumbs.db
